PORT=5174
HOST=127.0.0.1
DATABASE_PATH=./data/work-routes.sqlite

# Optional map APIs. MapQuest is tried first, then OpenRouteService.
# Without a key, the app works with local estimated routes.
MAPQUEST_API_KEY=
OPENROUTESERVICE_API_KEY=

# Optional future integrations.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENWEATHER_API_KEY=
WEATHERBIT_API_KEY=

# Local fallback settings used when no map API key is configured.
FALLBACK_AVERAGE_SPEED_KMH=52
FALLBACK_ROAD_FACTOR=1.22
